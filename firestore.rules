rules_version = '2';
// ── Regras de segurança do Firestore ────────────────────────────────────────
//
// Estratégia:
//   - Cada usuário só lê e escreve em /users/{seu_uid}/...
//   - Funciona tanto com login anônimo quanto com login Google
//   - Não existe acesso público a nenhum documento
//
// Como publicar:
//   firebase deploy --only firestore:rules
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Nenhum acesso por padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Usuário autenticado só acessa seu próprio namespace
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
