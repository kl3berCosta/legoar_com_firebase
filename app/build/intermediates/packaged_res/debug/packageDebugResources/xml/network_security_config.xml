<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuração de segurança de rede.
    Firebase e ARCore precisam de HTTPS — este config garante
    que não haja texto puro acidentalmente em produção.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <!-- Permite tráfego claro apenas em debug (emulador/testes locais) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
